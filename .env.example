# Postgres connection string (cloud-hosted, reachable from both backend and Pi worker)
DATABASE_URL=postgres://user:password@host:5432/draftpilot

# Set to 'false' only if your Postgres host does not use SSL (e.g. local dev)
DATABASE_SSL=true

# 'development' enables TypeORM synchronize (auto-creates tables)
# 'production' disables synchronize — use migrations instead
NODE_ENV=development

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-random-secret

# Two app users — passwords are hashed with bcrypt at startup, never stored plaintext
USER1_USERNAME=kevin
USER1_PASSWORD=replace-me

USER2_USERNAME=john
USER2_PASSWORD=replace-me

# Frontend URL for CORS (must match exactly, including protocol and port)
ALLOWED_ORIGIN=http://localhost:5173

# Worker URL — only needed until queue architecture is complete (Phase 4)
WORKER_URL=http://localhost:4000
