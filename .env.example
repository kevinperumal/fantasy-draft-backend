# Postgres connection string (cloud-hosted, reachable from both backend and Pi worker)
DATABASE_URL=postgres://user:password@host:5432/draftpilot

# Set to 'false' only if your Postgres host does not use SSL (e.g. local dev)
DATABASE_SSL=true

# 'development' enables TypeORM synchronize (auto-creates tables)
# 'production' disables synchronize — use migrations instead
NODE_ENV=development

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-random-secret

# Two app users — passwords are hashed with bcrypt at startup, never stored plaintext
USER1_USERNAME=kevin
USER1_PASSWORD=replace-me

USER2_USERNAME=john
USER2_PASSWORD=replace-me

# Frontend URL for CORS (must match exactly, including protocol and port)
ALLOWED_ORIGIN=http://localhost:5173

# Google service account credentials JSON (single-line or multi-line).
# Create a service account in Google Cloud Console, download the JSON key,
# and paste the entire contents here. Share your template sheet with the
# service account email (editor access).
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheets template spreadsheet ID to duplicate when a new draft is created.
# Leave blank to skip sheet provisioning (sheetUrl will be null on the draft).
SHEET_TEMPLATE_ID=

# The legacy/fallback spreadsheet used by the highlightPlayer pick tracker.
# Spreadsheet ID (from the sheet URL) and the integer sheet tab ID.
SHEETS_SPREADSHEET_ID=
SHEETS_SHEET_ID=0

# ── AI Recommendations (Phase 6) ─────────────────────────────────────────────

# Anthropic API key for Claude-powered pick recommendations
ANTHROPIC_API_KEY=

# Claude model to use for recommendations (default: claude-sonnet-4-6)
# Use claude-haiku-4-5-20251001 for faster/cheaper responses
AI_MODEL=claude-sonnet-4-6

# Spreadsheet row range to read for player metadata (default: A2:H, skips header row)
SHEET_PLAYER_RANGE=A2:H

# Column indices (0-based) for player metadata in the spreadsheet.
# Defaults assume: A=RW rank, B=name, C=NFL team, D=position, E=ESPN rank, F=ADP, G=pitcher flag, H=closer rank
SHEET_COL_ROTOWIRE_RANK=0
SHEET_COL_NAME=1
SHEET_COL_NFL_TEAM=2
SHEET_COL_POSITION=3
SHEET_COL_ESPN_RANK=4
SHEET_COL_ADP=5
SHEET_COL_PITCHER=6
SHEET_COL_CLOSER_RANK=7

# Shared secret for POST /picks — set to a random string; same value on Pi worker
PICK_SECRET=
